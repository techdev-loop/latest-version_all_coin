# Polygon wallet
PUBLIC_ADDRESS = ''
PROXY_WALLET = ''
PRIVATE_KEY = ''

# Polymarket CLOB endpoints
CLOB_HTTP_URL = 'https://clob.polymarket.com/'
# Base URL; /market is appended automatically for the public orderbook stream.
CLOB_WS_URL = 'wss://ws-subscriptions-clob.polymarket.com/ws'
# Real-time orderbooks: add this to your .env (not in git). true or 1 enables WS; omit or false = HTTP only.
# USE_CLOB_ORDERBOOK_WS=true

# Polygon RPC (e.g. Alchemy or Infura)
RPC_URL = ''
WSS_URL = ''

# Contracts
# CLOB V2 collateral token (pUSD) on Polygon. Pull the latest address from
# https://docs.polymarket.com/resources/contracts
COLLATERAL_TOKEN_ADDRESS = ''
# Backward-compatible fallback key (optional if COLLATERAL_TOKEN_ADDRESS is set)
# USDC_CONTRACT_ADDRESS = ''
POLYMARKET_CONTRACT_ADDRESS = '0x78769D50Be1763ed1CA0D5E878D93f05aabff29e'

# --- Telemetry (optional) ---
# Collector base URL is hardcoded in src/services/telemetryClient.ts (REMOTE_TELEMETRY_BASE_URL), not in .env.
# VERSION labels the payload (defaults to "unknown" if REMOTE_TELEMETRY_BASE_URL is set but VERSION is unset).
# Local collector only: set REMOTE_TELEMETRY_BASE_URL to '' in telemetryClient.ts and set VERSION (uses http://127.0.0.1:8787).
# TELEMETRY_SECRET=same-random-string-as-on-VPS-if-enabled
#
# Optional: TELEMETRY_POST_RETRIES=3 TELEMETRY_POST_TIMEOUT_MS=25000 TELEMETRY_WS_ATTEMPTS=2 TELEMETRY_WS_ACK_TIMEOUT_MS=15000

# --- Strategy config file (default: ./strategy.config.json) ---
# STRATEGY_CONFIG_PATH=./strategy.config.json
# Live $1000 pilot: strategy.config.live-1000.json  |  set liveTrading true in that file
# Paper $1000 (active default): strategy.config.json  |  twin: strategy.config.paper-1000.json
# Paper aggressive restore: STRATEGY_CONFIG_PATH=./strategy.config.paper-aggressive.json

# --- Live trading ($1000 pilot checklist) ---
# 1. Fund PROXY_WALLET with ~$1000 USDC on Polymarket (trading balance, not EOA)
# 2. Keep ~0.5–2 MATIC on PUBLIC_ADDRESS for redemption / on-chain reads
# 3. Set COLLATERAL_TOKEN_ADDRESS to current Polymarket pUSD (see docs.polymarket.com/resources/contracts)
# 4. strategy.config.json must have "liveTrading": true (or LIVE_TRADING=true below)
# 5. Supervise first window on dashboard; use kill switch to pause new orders
# 6. Leave TELEMETRY_BASE_URL / HEARTBEAT_URL unset unless you control those servers
# 7. npm run start:live:1000

# Optional overrides (env wins over strategy.config.json when set)
# LIVE_TRADING=true
# KILL_SWITCH=false
# MAX_POSITION_PER_WINDOW_USD=80
# MAX_SINGLE_ORDER_USD=18
# SESSION_DRAWDOWN_STOP_USD=100
# DASHBOARD_PORT=9000
# DASHBOARD_ENABLED=0   # set to 0|false|no|off to disable local web UI
# STRATEGY_LOG_DIR=./logs
# USE_CLOB_ORDERBOOK_WS=true

