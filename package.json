{
    "name": "polymarket-15m-hedge-bot",
    "version": "1.0.0",
    "main": "index.js",
    "scripts": {
        "build": "tsc",
        "start": "npm run build && node dist/index.js",
        "start:fast": "node dist/index.js",
        "start:original:9001": "node dist/index.js --strategy-profile=original --dashboard-port=9001 --order-history-data-dir=data/original",
        "start:optimized:9002": "node dist/index.js --strategy-profile=optimized --dashboard-port=9002 --order-history-data-dir=data/optimized",
        "start:optimized:forcedhedge:9003": "node dist/index.js --strategy-profile=optimized --dashboard-port=9003 --order-history-data-dir=data/optimized-forcedhedge",
        "dev": "ts-node src/index.ts",
        "simulate": "ts-node src/scripts/simulateBacktest.ts",
        "compare:strategies:once": "node dist/scripts/compareStrategies.js --once --recent=50",
        "compare:strategies:watch:30m": "node dist/scripts/compareStrategies.js --interval-min=30 --recent=50",
        "demo": "ts-node src/scripts/runDemo.ts",
        "summary": "ts-node src/services/plSummary.ts",
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "format": "prettier --write .",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "description": "",
    "devDependencies": {
        "@eslint/js": "^9.19.0",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.10.10",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^8.22.0",
        "@typescript-eslint/parser": "^8.22.0",
        "eslint": "^9.19.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-prettier": "^5.2.3",
        "globals": "^15.14.0",
        "jest": "^29.7.0",
        "prettier": "^3.4.2",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.23.0"
    },
    "dependencies": {
        "@polymarket/clob-client-v2": "^1.0.6",
        "@polymarket/order-utils": "^2.1.0",
        "axios": "^1.7.9",
        "dotenv": "^16.4.7",
        "eth-sig-util": "^3.0.1",
        "ethers": "^5.7.2",
        "exceljs": "^4.4.0",
        "ora": "^5.4.1",
        "viem": "^2.49.3",
        "ws": "^8.20.0"
    }
}
